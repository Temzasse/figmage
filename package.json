{
  "name": "figmage",
  "version": "1.1.0",
  "description": "Flexibly generate design tokens from your Figma files",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git://github.com/Temzasse/figmage.git"
  },
  "scripts": {
    "test": "echo TODO",
    "build": "tsdown --on-success \"npm run example:link\"",
    "build:watch": "tsdown --watch ./src --on-success \"npm run example:update\"",
    "format": "biome format",
    "lint": "biome check",
    "example:update": "yalc push --replace",
    "example:tokenize": "cd example && npm run tokenize",
    "example:codegen": "cd example && npm run codegen",
    "example:spritesheet": "bin/figmage spritesheet --sprite-input ./example/spritesheet/icons --sprite-out-dir ./example/spritesheet/public --sprite-ids-out-dir ./example/spritesheet",
    "example:spritesheet:serve": "npx serve ./example/spritesheet",
    "release": "np --any-branch"
  },
  "bin": {
    "figmage": "bin/figmage"
  },
  "files": [
    "bin/",
    "src/",
    "dist/"
  ],
  "keywords": [
    "cli",
    "figma",
    "figma api",
    "token",
    "design",
    "system",
    "design system",
    "design tokens",
    "sync"
  ],
  "author": {
    "name": "Teemu Taskula",
    "email": "taskuteemu@gmail.com",
    "url": "https://github.com/Temzasse"
  },
  "engines": {
    "node": ">=20.19"
  },
  "dependencies": {
    "@figma/rest-api-spec": "0.32.0",
    "consola": "3.4.2",
    "dotenv": "17.0.1",
    "lodash.camelcase": "4.3.0",
    "lodash.get": "4.4.2",
    "lodash.kebabcase": "4.1.1",
    "lodash.snakecase": "4.1.1",
    "lodash.template": "4.5.0",
    "svgo": "4.0.0"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "0.18.2",
    "@biomejs/biome": "2.0.6",
    "@types/node": "24.0.10",
    "tsdown": "0.12.9",
    "typescript": "5.8.3"
  },
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  }
}
