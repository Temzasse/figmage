{
  "name": "figmage",
  "version": "1.1.0",
  "description": "Flexibly generate design tokens from your Figma files",
  "keywords": [
    "cli",
    "design",
    "design system",
    "design tokens",
    "figma",
    "figma api",
    "sync",
    "system",
    "token"
  ],
  "license": "MIT",
  "author": {
    "name": "Teemu Taskula",
    "email": "taskuteemu@gmail.com",
    "url": "https://github.com/Temzasse"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/Temzasse/figmage.git"
  },
  "bin": {
    "figmage": "bin/figmage"
  },
  "files": [
    "bin/",
    "src/",
    "dist/"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "echo TODO",
    "dev": "tsdown --watch ./src --on-success \"npm run example:update\"",
    "build": "tsdown",
    "release": "npm run verify && npm run build && np",
    "verify": "run-p format:check lint:check typecheck",
    "format:check": "oxfmt --check ./src",
    "format:fix": "oxfmt ./src",
    "lint:check": "oxlint ./src",
    "lint:fix": "oxlint --fix ./src",
    "typecheck": "tsc --noEmit",
    "example:link": "cd example && yalc add figmage && npm i",
    "example:update": "yalc push --replace",
    "example:sync": "cd example && npm run sync",
    "example:sprites": "cd example && npm run sprites:generate",
    "example:sprites:serve": "cd example && npm run sprites:serve"
  },
  "dependencies": {
    "@figma/rest-api-spec": "0.40.0",
    "color-convert": "3.1.3",
    "consola": "3.4.2",
    "svgo": "4.0.1"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "0.18.3",
    "@types/node": "25.9.1",
    "npm-run-all": "4.1.5",
    "oxfmt": "0.53.0",
    "oxlint": "1.68.0",
    "tsdown": "0.22.1",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=22"
  }
}
